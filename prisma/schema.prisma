generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = "postgresql://user@localhost:5432/viadb?schema=public"
}

model InventoryItem {
  id           Int      @id @default(autoincrement())
  name         String
  sku          String   @unique
  category     String
  location     String
  quantity     Int
  reorderLevel Int
  unitCost     Float
  createdAt    DateTime @default(now())
}
