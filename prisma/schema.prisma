generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = "postgresql://user@localhost:5432/viadb?schema=public"
}

model WeightEntry {
  id         Int      @id @default(autoincrement())
  weight     Float
  recordedAt DateTime
  note       String?
  createdAt  DateTime @default(now())
}

model Goal {
  id             Int      @id @default(autoincrement())
  startingWeight Float
  targetWeight   Float
  targetDate     DateTime?
  updatedAt      DateTime @updatedAt
}
